{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/srkyn/stigpilot/docs/schemas/changes.schema.json",
  "title": "STIGPilot Changes Export",
  "description": "Machine-readable STIG change intelligence generated by STIGPilot.",
  "type": "object",
  "required": ["schema_version", "schema", "source", "summary", "changes"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "description": "Version of the STIGPilot changes JSON contract.",
      "const": "1.0"
    },
    "schema": {
      "type": "string",
      "description": "Repository-relative path to this schema document."
    },
    "source": {
      "type": "object",
      "required": [
        "old_file",
        "new_file",
        "old_title",
        "new_title",
        "old_version",
        "new_version",
        "old_release",
        "new_release",
        "old_control_count",
        "new_control_count"
      ],
      "additionalProperties": false,
      "properties": {
        "old_file": {"type": "string"},
        "new_file": {"type": "string"},
        "old_title": {"type": "string"},
        "new_title": {"type": "string"},
        "old_version": {"type": "string"},
        "new_version": {"type": "string"},
        "old_release": {"type": "string"},
        "new_release": {"type": "string"},
        "old_control_count": {"type": "integer", "minimum": 0},
        "new_control_count": {"type": "integer", "minimum": 0}
      }
    },
    "summary": {
      "type": "object",
      "required": [
        "total",
        "added",
        "removed",
        "modified",
        "severity_changed",
        "high_priority_review",
        "implementation_change_likely",
        "evidence_update_likely"
      ],
      "additionalProperties": false,
      "properties": {
        "total": {"type": "integer", "minimum": 0},
        "added": {"type": "integer", "minimum": 0},
        "removed": {"type": "integer", "minimum": 0},
        "modified": {"type": "integer", "minimum": 0},
        "severity_changed": {"type": "integer", "minimum": 0},
        "high_priority_review": {"type": "integer", "minimum": 0},
        "implementation_change_likely": {"type": "integer", "minimum": 0},
        "evidence_update_likely": {"type": "integer", "minimum": 0}
      }
    },
    "changes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "change_type",
          "impact",
          "impact_label",
          "reason",
          "changed_fields",
          "suggested_owner",
          "evidence_needed",
          "control"
        ],
        "additionalProperties": false,
        "properties": {
          "change_type": {"type": "string"},
          "impact": {
            "type": "string",
            "enum": [
              "high_priority_review",
              "implementation_change_likely",
              "evidence_update_likely",
              "review_recommended",
              "no_action_likely"
            ]
          },
          "impact_label": {"type": "string"},
          "reason": {"type": "string"},
          "changed_fields": {
            "type": "array",
            "items": {"type": "string"}
          },
          "suggested_owner": {"type": "string"},
          "evidence_needed": {
            "type": "array",
            "items": {"type": "string"}
          },
          "control": {
            "type": "object",
            "required": [
              "title",
              "vuln_id",
              "rule_id",
              "group_id",
              "stig_id",
              "severity",
              "tags",
              "cci_refs",
              "references",
              "check_summary",
              "fix_summary"
            ],
            "additionalProperties": false,
            "properties": {
              "title": {"type": "string"},
              "vuln_id": {"type": "string"},
              "rule_id": {"type": "string"},
              "group_id": {"type": "string"},
              "stig_id": {"type": "string"},
              "severity": {"type": "string"},
              "tags": {
                "type": "array",
                "items": {"type": "string"}
              },
              "cci_refs": {
                "type": "array",
                "items": {"type": "string"}
              },
              "references": {
                "type": "array",
                "items": {"type": "string"}
              },
              "check_summary": {"type": "string"},
              "fix_summary": {"type": "string"}
            }
          }
        }
      }
    }
  }
}
