<?xml version="1.0" encoding="UTF-8"?>
<Benchmark xmlns="http://checklists.nist.gov/xccdf/1.2" xmlns:dc="http://purl.org/dc/elements/1.1/" id="synthetic-old">
  <title>Synthetic Windows and Linux STIG</title>
  <status date="2026-01-01">Release 1</status>
  <version>V1R1</version>
  <Group id="V-100001">
    <Rule id="SV-100001r1_rule" severity="medium">
      <version>APP-AU-000001</version>
      <title>Windows audit policy must be configured</title>
      <description>&lt;VulnDiscussion&gt;Audit policy gaps reduce investigation quality.&lt;/VulnDiscussion&gt;</description>
      <ident system="http://cyber.mil/cci">CCI-000001</ident>
      <check system="C-100001">
        <check-content>Review Windows audit policy settings in Local Security Policy.</check-content>
      </check>
      <fixtext fixref="F-100001">Configure Windows audit policy through GPO.</fixtext>
      <reference href="https://example.invalid/audit"><dc:title>Audit policy reference</dc:title></reference>
    </Rule>
  </Group>
  <Group id="V-100002">
    <Rule id="SV-100002r1_rule" severity="low">
      <version>APP-LX-000010</version>
      <title>Linux SSH banner must be configured</title>
      <ident system="http://cyber.mil/cci">CCI-000002</ident>
      <check><check-content>Run sshd -T and review the banner setting.</check-content></check>
      <fixtext>Configure the sshd Banner directive in /etc/ssh/sshd_config.</fixtext>
    </Rule>
  </Group>
  <Group id="V-100003">
    <Rule id="SV-100003r1_rule" severity="medium">
      <version>APP-DB-000020</version>
      <title>Removed database audit control</title>
      <check><check-content>Review SQL audit settings.</check-content></check>
      <fixtext>Configure SQL audit settings.</fixtext>
    </Rule>
  </Group>
</Benchmark>
